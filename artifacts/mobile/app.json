{
  "expo": {
    "name": "Travel Map",
    "slug": "travel-map",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "travelmap",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cozturk.travelmap",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Travel Map reads GPS metadata from your photos to automatically build your personal travel history. No photos are uploaded or shared.",
        "NSLocationWhenInUseUsageDescription": "Location is used to identify places from your photo GPS data."
      }
    },
    "android": {
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-media-library",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Travel Map uses location services to identify countries and cities from your photo GPS data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}