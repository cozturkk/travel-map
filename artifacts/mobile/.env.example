# Cloud account + stats sync (Profile tab). Optional — the app runs fine
# without these; the cloud section stays hidden until both are set.
#
# 1. Create a free project at https://supabase.com
# 2. Project Settings → API → copy the values below
# 3. Run supabase/schema.sql in the Supabase SQL editor
# 4. Restart the Expo dev server so these are picked up

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
